# ── LLM Providers ────────────────────────────────────────────────────────────
# Set only the keys for providers you intend to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=

# Ollama (local) base URL — no key needed
OLLAMA_BASE_URL=http://localhost:11434

# ── Active provider defaults ──────────────────────────────────────────────────
DATAFORGE_LLM_PROVIDER=openai
DATAFORGE_LLM_MODEL=gpt-4o-mini
DATAFORGE_LLM_TEMPERATURE=0.7
DATAFORGE_LLM_MAX_TOKENS=2048

# ── Export targets ────────────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Pipeline defaults ─────────────────────────────────────────────────────────
DATAFORGE_RATE_LIMIT=2          # requests per second (per domain)
DATAFORGE_MAX_PAGES=500         # max pages to scrape per session
DATAFORGE_MAX_CRAWL_PAGES=50    # max pages discovered by BFS crawler (sitemap fallback)
DATAFORGE_MAX_CRAWL_DEPTH=3     # max link depth for BFS crawler
DATAFORGE_CHUNK_SIZE=512        # tokens per chunk
DATAFORGE_CHUNK_OVERLAP=64      # token overlap between chunks
DATAFORGE_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
DATAFORGE_OUTPUT_DIR=./output   # base output directory
DATAFORGE_DB_PATH=./dataforge.db
